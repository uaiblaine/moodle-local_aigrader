{{!
    @template local_aigrader/bulk_confirm

    Confirmation page rendered by bulk.php before a destructive action is
    applied to the selected submissions. Shows how many rows will be touched,
    how many will be skipped (and why), and a confirm/cancel pair of buttons.

    Context variables required for this template:
    * action_label - Human label of the action ("Publicar tal cual").
    * action_warning - Sentence describing what the action will do.
    * ok_count - Number of submissions that will be processed.
    * has_skips - Whether to render the skip summary block.
    * skip_lines - Array of {count, reason} for the skip summary.
    * submit_url - URL the confirm form posts back to (bulk.php again).
    * cancel_url - URL the cancel link goes to (manage.php).
    * hidden_inputs - Array of {name, value} re-posted on confirm.
    * confirm_button - Label for the confirm button.
    * cancel_button - Label for the cancel link.

    Example context (json):
    {
        "action_label": "Publicar tal cual",
        "action_warning": "Vas a publicar las notas propuestas por la IA tal cual están, sin editarlas. Las notas se escribirán en el cuaderno de calificaciones.",
        "ok_count": 22,
        "has_skips": true,
        "skip_lines": [
            { "count": 1, "reason": "Ya publicada" },
            { "count": 2, "reason": "Formato no soportado" }
        ],
        "submit_url": "/local/aigrader/bulk.php",
        "cancel_url": "/local/aigrader/manage.php?cmid=5",
        "hidden_inputs": [
            { "name": "sesskey",   "value": "abc123" },
            { "name": "cmid",      "value": 5 },
            { "name": "action",    "value": "approve_publish" },
            { "name": "confirm",   "value": 1 },
            { "name": "ids[]",     "value": 1 }
        ],
        "confirm_button": "Sí, publicar",
        "cancel_button":  "Cancelar"
    }
}}
<div class="card mb-3">
    <div class="card-body">
        <h3 class="card-title">{{action_label}}</h3>
        <p class="card-text">{{action_warning}}</p>
        <p class="card-text">
            <strong>{{ok_count}}</strong>
            {{#str}} bulk_confirm_count, local_aigrader {{/str}}
        </p>
        {{#has_skips}}
            <div class="alert alert-warning mb-3">
                <p class="mb-1"><strong>{{#str}} bulk_confirm_skipped_header, local_aigrader {{/str}}</strong></p>
                <ul class="mb-0">
                    {{#skip_lines}}
                        <li>{{count}} · {{reason}}</li>
                    {{/skip_lines}}
                </ul>
            </div>
        {{/has_skips}}
        <form action="{{submit_url}}" method="post" class="d-flex gap-2">
            {{#hidden_inputs}}
                <input type="hidden" name="{{name}}" value="{{value}}">
            {{/hidden_inputs}}
            <button type="submit" class="btn btn-danger">{{confirm_button}}</button>
            <a href="{{cancel_url}}" class="btn btn-secondary">{{cancel_button}}</a>
        </form>
    </div>
</div>
